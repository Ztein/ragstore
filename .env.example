# --- ragstore configuration (copy to .env; never commit real secrets) ---

# Inbound Bearer auth (required). Clients send: Authorization: Bearer <key>
RAGSTORE_API_KEY=change-me

# SQLite file (registry + job queue). In the container this defaults to /data/ragstore.db.
SQLITE_PATH=./data/ragstore.db

# Weaviate (vectors + hybrid search)
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
# WEAVIATE_API_KEY=

# Embeddings — external OpenAI-compatible provider (required). EMBEDDING_DIM must
# match the model's output dimension; a mismatch fails loud at index time.
EMBEDDING_BASE_URL=https://your-openai-compatible-endpoint/v1
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_API_KEY=change-me
EMBEDDING_DIM=1024

# Generation LLM — external OpenAI-compatible provider. Only required when a query
# uses `generate`. Leave unset to disable generation.
# LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
# LLM_MODEL=your-chat-model
# LLM_API_KEY=change-me
